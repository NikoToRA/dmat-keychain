---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="注文確認 - DMAT STORE">
  <div class="max-w-4xl mx-auto px-6 py-8">
    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-400 mb-6">
      <a href="/" class="hover:text-dmat-navy transition-colors">トップ</a>
      <span class="mx-1">/</span>
      <a href="/cart" class="hover:text-dmat-navy transition-colors">カート</a>
      <span class="mx-1">/</span>
      <span class="text-gray-600">注文確認</span>
    </nav>

    <!-- Step Indicator -->
    <div class="flex items-center justify-center gap-2 mb-10">
      <div class="flex items-center gap-2">
        <div class="step-indicator completed">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        </div>
        <span class="text-xs text-gray-500 hidden sm:block">カート</span>
      </div>
      <div class="w-8 h-px bg-gray-300"></div>
      <div class="flex items-center gap-2">
        <div class="step-indicator">2</div>
        <span class="text-xs font-bold text-dmat-navy hidden sm:block">確認</span>
      </div>
      <div class="w-8 h-px bg-gray-300"></div>
      <div class="flex items-center gap-2">
        <div class="step-indicator inactive">3</div>
        <span class="text-xs text-gray-400 hidden sm:block">決済</span>
      </div>
    </div>

    <h1 class="text-2xl font-bold text-dmat-navy mb-8">注文確認</h1>

    <div id="confirm-content"></div>
  </div>
</BaseLayout>

<script is:inline>
(function () {
  'use strict';

  var BASE_PRODUCT = { id: 'dmat-keychain', name: 'DMAT キーホルダー', basePrice: 680 };

  function calculateShipping(qty) {
    if (qty <= 0) return { method: null, price: 0 };
    if (qty <= 4) return { method: 'クリックポスト', price: 185 };
    var packs = Math.ceil(qty / 15);
    return { method: 'レターパックライト' + (packs > 1 ? ' ×' + packs : ''), price: 370 * packs };
  }

  function getCart() {
    try { return JSON.parse(localStorage.getItem('dmat_cart') || '[]'); } catch (e) { return []; }
  }

  function render() {
    var container = document.getElementById('confirm-content');
    if (!container) return;
    var cart = getCart();

    if (cart.length === 0) {
      container.innerHTML =
        '<div class="text-center py-16">' +
          '<p class="text-gray-500 text-sm mb-6">カートに商品がありません</p>' +
          '<a href="/" class="btn-primary">商品を見る</a>' +
        '</div>';
      return;
    }

    var totalQty = cart.reduce(function (sum, item) { return sum + item.quantity; }, 0);
    var subtotal = cart.reduce(function (sum, item) { return sum + (item.unitPrice * item.quantity); }, 0);
    var shipping = calculateShipping(totalQty);
    var total = subtotal + shipping.price;

    // Estimate delivery (10 business days from now)
    var today = new Date();
    var deliveryDate = new Date(today);
    deliveryDate.setDate(deliveryDate.getDate() + 14);
    var deliveryStr = (deliveryDate.getMonth() + 1) + '月' + deliveryDate.getDate() + '日頃';

    var rowsHtml = cart.map(function (item) {
      var lineTotal = item.unitPrice * item.quantity;
      return '<tr class="border-b border-gray-100">' +
        '<td class="py-3 text-sm text-gray-700">' + (item.description || BASE_PRODUCT.name) + '</td>' +
        '<td class="py-3 text-sm text-gray-700 text-center">' + item.quantity + '</td>' +
        '<td class="py-3 text-sm text-gray-700 text-right">&yen;' + item.unitPrice.toLocaleString() + '</td>' +
        '<td class="py-3 text-sm font-medium text-dmat-navy text-right">&yen;' + lineTotal.toLocaleString() + '</td>' +
      '</tr>';
    }).join('');

    container.innerHTML =
      '<div class="overflow-x-auto">' +
        '<table class="w-full">' +
          '<thead>' +
            '<tr class="border-b-2 border-gray-200">' +
              '<th class="py-2 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">商品名</th>' +
              '<th class="py-2 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">数量</th>' +
              '<th class="py-2 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">単価</th>' +
              '<th class="py-2 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">小計</th>' +
            '</tr>' +
          '</thead>' +
          '<tbody>' + rowsHtml + '</tbody>' +
        '</table>' +
      '</div>' +
      '<div class="mt-6 bg-gray-50 rounded-xl p-6">' +
        '<div class="space-y-3">' +
          '<div class="flex justify-between text-sm">' +
            '<span class="text-gray-500">小計</span>' +
            '<span class="font-medium text-dmat-navy">&yen;' + subtotal.toLocaleString() + '</span>' +
          '</div>' +
          '<div class="flex justify-between text-sm">' +
            '<span class="text-gray-500">送料' + (shipping.method ? ' (' + shipping.method + ')' : '') + '</span>' +
            '<span class="font-medium text-dmat-navy">&yen;' + shipping.price.toLocaleString() + '</span>' +
          '</div>' +
          '<div class="border-t border-gray-200 pt-3 flex justify-between">' +
            '<span class="font-bold text-dmat-navy">合計 (税込)</span>' +
            '<span class="text-xl font-bold text-dmat-navy">&yen;' + total.toLocaleString() + '</span>' +
          '</div>' +
        '</div>' +
      '</div>' +
      '<div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4">' +
        '<h3 class="text-sm font-bold text-amber-800 mb-2">ご注意事項</h3>' +
        '<ul class="text-xs text-amber-700 space-y-1 list-disc list-inside">' +
          '<li>本商品は受注生産です</li>' +
          '<li>ご注文確定後、10日以内に発送いたします</li>' +
          '<li>受注生産品のため、不良品以外の返品・交換はお受けできません</li>' +
        '</ul>' +
      '</div>' +
      '<div class="mt-4 rounded-xl border border-blue-200 bg-blue-50 p-4">' +
        '<h3 class="text-sm font-bold text-blue-800 mb-1">配送目安</h3>' +
        '<p class="text-xs text-blue-700">お届け予定: ' + deliveryStr + '（製作10日 + 配送2〜4日）</p>' +
      '</div>' +
      '<div class="mt-8">' +
        '<label class="flex items-start gap-3 cursor-pointer mb-6">' +
          '<input type="checkbox" id="agree-checkbox" class="mt-1 w-4 h-4 rounded" />' +
          '<span class="text-xs" style="color: var(--color-text-secondary); line-height: 1.6;">' +
            '<a href="/legal/protection" target="_blank" class="underline" style="color: var(--color-primary);">個人情報保護方針</a>および' +
            '<a href="/legal/privacy" target="_blank" class="underline" style="color: var(--color-primary);">プライバシーポリシー</a>に同意のうえ、ご注文ください。' +
          '</span>' +
        '</label>' +
        '<div class="flex flex-col sm:flex-row gap-3">' +
          '<a href="/cart" class="btn-secondary flex-1 text-center">カートに戻る</a>' +
          '<button id="checkout-button" class="btn-primary flex-1 text-center" disabled style="opacity:0.4;cursor:not-allowed;">注文を確定して決済へ進む</button>' +
        '</div>' +
      '</div>';

    // 同意チェックボックス
    var agreeBox = document.getElementById('agree-checkbox');
    var checkoutBtn = document.getElementById('checkout-button');
    agreeBox.addEventListener('change', function () {
      checkoutBtn.disabled = !this.checked;
      checkoutBtn.style.opacity = this.checked ? '1' : '0.4';
      checkoutBtn.style.cursor = this.checked ? 'pointer' : 'not-allowed';
    });

    // Checkout handler
    checkoutBtn.addEventListener('click', function () {
      var btn = this;
      btn.disabled = true;
      btn.textContent = '処理中...';
      btn.style.opacity = '0.7';

      var items = cart.map(function (item) {
        return {
          id: item.id,
          colorId: item.colorId,
          accessoryIds: item.accessoryIds,
          quantity: item.quantity,
          unitPrice: item.unitPrice,
          category: item.category || 'dmat-member',
          description: item.description
        };
      });

      fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: items })
      })
      .then(function (res) {
        if (!res.ok) throw new Error('Checkout failed');
        return res.json();
      })
      .then(function (data) {
        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error('No checkout URL returned');
        }
      })
      .catch(function (err) {
        btn.disabled = false;
        btn.textContent = '注文を確定して決済へ進む';
        btn.style.opacity = '1';
        var toast = document.createElement('div');
        toast.className = 'toast toast-error';
        toast.textContent = '決済の開始に失敗しました。もう一度お試しください。';
        var tc = document.getElementById('toast-container');
        if (tc) {
          tc.appendChild(toast);
          requestAnimationFrame(function () { toast.classList.add('toast-visible'); });
          setTimeout(function () {
            toast.classList.remove('toast-visible');
            setTimeout(function () { toast.remove(); }, 300);
          }, 3000);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }
})();
</script>
