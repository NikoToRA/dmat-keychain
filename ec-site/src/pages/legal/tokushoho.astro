---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="特定商取引法に基づく表記 - DMAT STORE">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-[#1B2838] transition-colors">トップ</a>
      <span class="mx-2">&gt;</span>
      <span>特定商取引法に基づく表記</span>
    </nav>

    <h1 class="text-2xl font-bold text-[#1B2838] mb-6">特定商取引法に基づく表記</h1>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="w-full text-sm">
        <tbody>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left w-1/3 text-gray-500 font-medium bg-gray-50 align-top">販売業者</th>
            <td class="py-4 px-6 text-gray-800">Wonder Drill株式会社</td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium align-top">代表責任者</th>
            <td class="py-4 px-6 text-gray-800">平山 傑</td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium bg-gray-50 align-top">所在地</th>
            <td class="py-4 px-6 text-gray-800">〒064-0805 北海道札幌市中央区南5条西15丁目2-3 リズム医大前 503号室</td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium align-top">連絡先</th>
            <td class="py-4 px-6 text-gray-800">
              <a href="mailto:support@wonder-drill.com" class="text-[#1B2838] hover:underline">support@wonder-drill.com</a>
            </td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium bg-gray-50 align-top">販売価格</th>
            <td class="py-4 px-6 text-gray-800">各商品ページに表示（税込価格）</td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium align-top">送料</th>
            <td class="py-4 px-6 text-gray-800">
              1~4個: &yen;185（クリックポスト）<br />
              5~15個: &yen;370（レターパックライト）<br />
              16個以上: &yen;370 &times; 口数（15個ごとにレターパックライト1口追加）
            </td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium bg-gray-50 align-top">支払方法</th>
            <td class="py-4 px-6 text-gray-800">クレジットカード決済（Stripe: Visa / Mastercard / JCB / Amex）</td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium align-top">支払時期</th>
            <td class="py-4 px-6 text-gray-800">注文確定時に即時決済</td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium bg-gray-50 align-top">引渡し時期</th>
            <td class="py-4 px-6 text-gray-800">受注生産、注文確定後10日以内に発送</td>
          </tr>
          <tr class="border-b border-gray-100">
            <th class="py-4 px-6 text-left text-gray-500 font-medium align-top">返品・交換</th>
            <td class="py-4 px-6 text-gray-800">受注生産品のためお客様都合による返品・交換は不可。不良品・破損品は到着後7日以内にご連絡いただければ交換対応いたします。</td>
          </tr>
          <tr>
            <th class="py-4 px-6 text-left text-gray-500 font-medium bg-gray-50 align-top">適格請求書発行事業者<br />登録番号</th>
            <td class="py-4 px-6 text-gray-800">T4430001092106</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
