---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="決済キャンセル - DMAT STORE">
  <div class="max-w-2xl mx-auto px-6 py-16 text-center">
    <!-- Amber warning icon -->
    <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-amber-100 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
      </svg>
    </div>

    <h1 class="text-2xl font-bold text-dmat-navy">決済がキャンセルされました</h1>
    <p class="text-sm text-gray-500 mt-3">お支払いは完了していません。カートの商品はそのまま保持されています。</p>

    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/cart" class="btn-primary">カートに戻る</a>
      <a href="/" class="btn-secondary">トップに戻る</a>
    </div>
  </div>
</BaseLayout>
