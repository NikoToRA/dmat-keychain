---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="DMAT STORE - NFC搭載DMAT装備販売"
  description="NFC搭載DMATキーホルダー。3Dプリント製、受注生産。DMAT隊員・災害拠点病院向け装備品。"
>
  <!-- Hero -->
  <section class="w-full relative">
    <div class="w-full bg-gray-900" style="aspect-ratio: 21/9;">
      <img
        src="/images/hero.webp"
        alt="DMAT隊員が災害現場で活動する様子"
        class="w-full h-full object-cover opacity-60"
      />
    </div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center px-6">
        <h1 class="text-white font-bold tracking-tight" style="font-size: clamp(1.5rem, 4vw, 3rem); letter-spacing: 0.08em;">NFC搭載DMAT装備販売</h1>
      </div>
    </div>
  </section>

  <!-- おすすめ商品 -->
  <section id="recommended" class="section-white" style="padding: 6rem 0;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-xs font-medium tracking-widest uppercase" style="color: var(--color-text-tertiary);">Recommended</span>
        <h2 class="font-bold mt-1" style="font-size: var(--text-3xl); color: var(--color-primary);">おすすめ商品</h2>
      </div>
      <div id="recommended-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children"></div>
      <div class="text-center mt-12 animate-on-scroll">
        <a href="/product?custom=true" class="btn-outline">自分のキーホルダーを作る</a>
      </div>
    </div>
  </section>

  <!-- 使い方・動画 -->
  <section class="section-white" style="padding: 6rem 0;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-xs font-medium tracking-widest uppercase" style="color: var(--color-text-tertiary);">How to Use</span>
        <h2 class="font-bold mt-1" style="font-size: var(--text-3xl); color: var(--color-primary);">キーホルダーの使い方</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- DMAT隊員向け -->
        <div class="animate-on-scroll">
          <div class="bg-gray-100 flex items-center justify-center" style="aspect-ratio: 16/9; border-radius: 12px;">
            <div class="text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="color: var(--color-text-tertiary);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
              </svg>
              <span class="text-xs" style="color: var(--color-text-tertiary);">動画準備中</span>
            </div>
          </div>
          <div class="mt-5">
            <span class="badge-pill badge-pill-navy">DMAT隊員向け</span>
            <h3 class="font-bold text-base mt-3" style="color: var(--color-primary);">災害出動。1秒でEMISへ。</h3>
            <p class="text-sm mt-2" style="color: var(--color-text-secondary); line-height: 1.8;">ブックマークや検索から解放。スマートフォンをかざすだけで、すぐにEMISへ接続できます。</p>
          </div>
        </div>
        <!-- 病院向け -->
        <div class="animate-on-scroll">
          <div class="bg-gray-100 flex items-center justify-center" style="aspect-ratio: 16/9; border-radius: 12px;">
            <div class="text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="color: var(--color-text-tertiary);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
              </svg>
              <span class="text-xs" style="color: var(--color-text-tertiary);">動画準備中</span>
            </div>
          </div>
          <div class="mt-5">
            <span class="badge-pill badge-pill-red">病院向け</span>
            <h3 class="font-bold text-base mt-3" style="color: var(--color-primary);">災害時、EMIS入力に迷わない。</h3>
            <p class="text-sm mt-2" style="color: var(--color-text-secondary); line-height: 1.8;">かざすだけで簡易マニュアル付きの特設サイトへ。検索不要で、必要な画面にすぐたどり着けます。</p>
            <a href="https://www.notion.so/EMIS-eb311c4c27dc46b9bf1dacd5b90db42f" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium mt-3 hover:underline" style="color: var(--color-accent);">
              病院向け特設サイトを見る
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- カテゴリー別 -->
  <section class="section-alt" style="padding: 6rem 0;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-xs font-medium tracking-widest uppercase" style="color: var(--color-text-tertiary);">Categories</span>
        <h2 class="font-bold mt-1" style="font-size: var(--text-3xl); color: var(--color-primary);">カテゴリーから探す</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 stagger-children">
        <!-- DMAT隊員用 -->
        <a href="/category?cat=dmat-member" class="category-card animate-on-scroll" style="background: linear-gradient(135deg, #1B2838 0%, #2a4060 100%);">
          <div class="absolute top-6 right-6 opacity-20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
            </svg>
          </div>
          <div class="relative z-10">
            <h3 class="text-white font-bold text-lg">DMAT隊員用グッズ</h3>
            <p class="text-white/70 text-sm mt-1">現場スタッフ向け</p>
          </div>
        </a>
        <!-- 病院用 -->
        <a href="/category?cat=hospital" class="category-card animate-on-scroll" style="background: linear-gradient(135deg, #C41E3A 0%, #e0475e 100%);">
          <div class="absolute top-6 right-6 opacity-20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <div class="relative z-10">
            <h3 class="text-white font-bold text-lg">病院用グッズ</h3>
            <p class="text-white/70 text-sm mt-1">病院・施設導入向け</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 自分で作る -->
  <section class="section-white" style="padding: 7rem 0;">
    <div class="max-w-lg mx-auto px-6 text-center animate-on-scroll">
      <span class="text-xs font-medium tracking-widest uppercase" style="color: var(--color-text-tertiary);">Custom Order</span>
      <h2 class="font-bold mt-1" style="font-size: var(--text-3xl); color: var(--color-primary);">自分のキーホルダーを作る</h2>
      <p class="text-sm mt-4" style="color: var(--color-text-secondary); line-height: 1.8;">カラーとアクセサリを選んで、あなただけの1本を。</p>
      <div class="mt-10">
        <a href="/product?custom=true" class="btn-primary">自分のキーホルダーを作る</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function () {
  'use strict';

  var BASE_PRODUCT = { id: 'dmat-keychain', name: 'DMAT キーホルダー', description: '3Dプリント製、NFC内蔵。DMATカラーのキーホルダー。', basePrice: 680, image: '/images/keychain-standard.webp' };
  var COLOR_VARIANTS = [
    { id: 'standard-red', name: 'スタンダードレッド', priceDiff: 0, image: '/images/keychain-standard.webp' },
    { id: 'premium-red', name: 'プレミアレッド', priceDiff: 0, image: '/images/keychain-premium.webp' }
  ];
  var ACCESSORIES = [
    { id: 'ball-chain', name: 'ボールチェーン', price: 0, isDefault: true, image: '/images/ball-chain.webp' },
    { id: 'carabiner', name: 'カラビナ', price: 300, isDefault: false, image: '/images/carabiner.webp' },
    { id: 'glow-band', name: '蓄光バンド', price: 400, isDefault: false, image: '/images/glow-band.webp' }
  ];
  var RECOMMENDED_SETS = [
    { id: 'basic', name: 'ベーシックセット', description: 'スタンダードレッド', color: 'standard-red', accessories: ['ball-chain'], badge: '定番', category: 'dmat-member' },
    { id: 'premium', name: 'プレミアムセット', description: 'プレミアレッド + カラビナ + 蓄光バンド', color: 'premium-red', accessories: ['ball-chain', 'carabiner', 'glow-band'], badge: 'フルセット', category: 'dmat-member' },
    { id: 'hospital-basic', name: '病院用ベーシック', description: 'スタンダードレッド', color: 'standard-red', accessories: ['ball-chain'], badge: '施設向け', category: 'hospital' },
    { id: 'hospital-glow', name: '病院用 蓄光バンド付き', description: 'スタンダードレッド + 蓄光バンド', color: 'standard-red', accessories: ['ball-chain', 'glow-band'], badge: '蓄光付き', category: 'hospital' }
  ];
  var CATEGORY_PRICE = { 'dmat-member': 0, 'hospital': 300 };

  function calcSetPrice(set) {
    var colorVar = COLOR_VARIANTS.find(function (c) { return c.id === set.color; });
    var price = BASE_PRODUCT.basePrice + (colorVar ? colorVar.priceDiff : 0);
    price += CATEGORY_PRICE[set.category] || 0;
    set.accessories.forEach(function (accId) {
      var acc = ACCESSORIES.find(function (a) { return a.id === accId; });
      if (acc) price += acc.price;
    });
    return price;
  }

  function getCart() {
    try { return JSON.parse(localStorage.getItem('dmat_cart') || '[]'); } catch (e) { return []; }
  }

  function saveCart(cart) {
    localStorage.setItem('dmat_cart', JSON.stringify(cart));
    window.dispatchEvent(new Event('cart-updated'));
  }

  function addSetToCart(set, qty) {
    qty = qty || 1;
    var cart = getCart();
    var price = calcSetPrice(set);
    var existing = cart.find(function (item) {
      return item.colorId === set.color && item.category === set.category && JSON.stringify(item.accessoryIds.sort()) === JSON.stringify(set.accessories.slice().sort());
    });
    if (existing) {
      existing.quantity += qty;
    } else {
      cart.push({
        id: BASE_PRODUCT.id + '-' + Date.now(),
        colorId: set.color,
        accessoryIds: set.accessories.slice(),
        quantity: qty,
        unitPrice: price,
        description: set.name,
        category: set.category
      });
    }
    saveCart(cart);
    showToast(set.name + ' × ' + qty + ' をカートに追加しました');
  }

  function showToast(message) {
    var container = document.getElementById('toast-container');
    if (!container) return;
    var toast = document.createElement('div');
    toast.className = 'toast toast-success';
    toast.textContent = message;
    container.appendChild(toast);
    requestAnimationFrame(function () {
      toast.classList.add('toast-visible');
    });
    setTimeout(function () {
      toast.classList.remove('toast-visible');
      setTimeout(function () { toast.remove(); }, 300);
    }, 2500);
  }

  function renderRecommended() {
    var grid = document.getElementById('recommended-grid');
    if (!grid) return;
    grid.innerHTML = RECOMMENDED_SETS.map(function (set) {
      var colorVar = COLOR_VARIANTS.find(function (c) { return c.id === set.color; });
      var price = calcSetPrice(set);
      var accNames = set.accessories.filter(function (accId) { return accId !== 'ball-chain'; }).map(function (accId) {
        var a = ACCESSORIES.find(function (x) { return x.id === accId; });
        return a ? a.name : '';
      }).filter(Boolean).join('、');
      return '<div class="product-card animate-on-scroll" data-set-id="' + set.id + '">' +
        '<a href="/product?set=' + set.id + '" class="block">' +
          '<div class="product-image-wrapper">' +
            '<img src="' + (colorVar ? colorVar.image : BASE_PRODUCT.image) + '" alt="' + set.name + '" class="w-full h-full object-contain p-4" onerror="this.style.display=\'none\'" />' +
          '</div>' +
        '</a>' +
        '<div class="p-4">' +
          '<div class="mb-2"><span class="badge-pill badge-pill-red">' + set.badge + '</span></div>' +
          '<a href="/product?set=' + set.id + '" class="block">' +
            '<h3 style="font-size: 0.875rem; font-weight: 500; color: var(--color-primary);">' + set.name + '</h3>' +
            '<p class="line-clamp-2" style="font-size: 0.75rem; color: var(--color-text-tertiary); margin-top: 0.25rem;">' + accNames + '</p>' +
          '</a>' +
          '<div style="margin-top: 0.75rem;">' +
            '<div style="font-size: 1rem; font-weight: 700; color: var(--color-primary); margin-bottom: 0.5rem;">&yen;' + price.toLocaleString() + '</div>' +
            '<div class="flex items-center gap-2">' +
              '<div class="flex items-center" style="border: 1px solid var(--color-border); border-radius: 6px; overflow: hidden;">' +
                '<button class="qty-minus" data-set-id="' + set.id + '" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; color: var(--color-text-secondary); border: none; background: none; cursor: pointer;">&minus;</button>' +
                '<span class="qty-display" data-set-id="' + set.id + '" style="padding: 0.25rem 0.375rem; font-size: 0.75rem; min-width: 1.5rem; text-align: center;">1</span>' +
                '<button class="qty-plus" data-set-id="' + set.id + '" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; color: var(--color-text-secondary); border: none; background: none; cursor: pointer;">&plus;</button>' +
              '</div>' +
              '<button class="add-set-btn" style="flex: 1; font-size: 0.75rem; color: #fff; background-color: var(--color-primary); border-radius: 6px; padding: 0.375rem 0.75rem; border: none; cursor: pointer; transition: opacity 150ms;" data-set-id="' + set.id + '" onmouseover="this.style.opacity=\'0.85\'" onmouseout="this.style.opacity=\'1\'">カートに入れる</button>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');

    grid.addEventListener('click', function (e) {
      // 数量ボタン
      var minus = e.target.closest('.qty-minus');
      var plus = e.target.closest('.qty-plus');
      if (minus || plus) {
        e.preventDefault();
        var sid = (minus || plus).getAttribute('data-set-id');
        var display = grid.querySelector('.qty-display[data-set-id="' + sid + '"]');
        if (display) {
          var val = parseInt(display.textContent) || 1;
          val = minus ? Math.max(1, val - 1) : Math.min(99, val + 1);
          display.textContent = val;
        }
        return;
      }
      // カートに入れる
      var btn = e.target.closest('.add-set-btn');
      if (!btn) return;
      e.preventDefault();
      var setId = btn.getAttribute('data-set-id');
      var set = RECOMMENDED_SETS.find(function (s) { return s.id === setId; });
      if (!set) return;
      var qtyEl = grid.querySelector('.qty-display[data-set-id="' + setId + '"]');
      var qty = qtyEl ? parseInt(qtyEl.textContent) || 1 : 1;
      addSetToCart(set, qty);
      if (qtyEl) qtyEl.textContent = '1';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderRecommended);
  } else {
    renderRecommended();
  }
})();
</script>
