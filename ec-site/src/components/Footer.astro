---
// Footer — Dieter Rams: every element must serve a purpose
const currentYear = new Date().getFullYear();
---

<footer style="background-color: var(--color-primary, #1B2838);" class="py-16" role="contentinfo" aria-label="サイト情報">
  <div class="mx-auto px-6" style="max-width: 72rem;">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">

      <!-- Brand -->
      <div>
        <p class="text-white font-bold text-base mb-3" style="letter-spacing: 0.06em;">
          DMAT STORE
        </p>
        <p class="text-sm" style="color: rgba(255, 255, 255, 0.5);">
          DMAT隊員・病院向けグッズ通販サイト
        </p>
      </div>

      <!-- Links -->
      <div>
        <p class="text-xs font-medium uppercase mb-4" style="letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.3);">
          Information
        </p>
        <ul class="space-y-3">
          <li>
            <a href="/legal/tokushoho" class="text-sm transition-colors" style="color: rgba(255, 255, 255, 0.6);"
              onmouseenter="this.style.color='rgba(255,255,255,0.9)'"
              onmouseleave="this.style.color='rgba(255,255,255,0.6)'"
            >
              特定商取引法に基づく表記
            </a>
          </li>
          <li>
            <a href="/legal/returns" class="text-sm transition-colors" style="color: rgba(255, 255, 255, 0.6);"
              onmouseenter="this.style.color='rgba(255,255,255,0.9)'"
              onmouseleave="this.style.color='rgba(255,255,255,0.6)'"
            >
              返品・交換について
            </a>
          </li>
          <li>
            <a href="/legal/privacy" class="text-sm transition-colors" style="color: rgba(255, 255, 255, 0.6);"
              onmouseenter="this.style.color='rgba(255,255,255,0.9)'"
              onmouseleave="this.style.color='rgba(255,255,255,0.6)'"
            >
              プライバシーポリシー
            </a>
          </li>
          <li>
            <a href="/legal/protection" class="text-sm transition-colors" style="color: rgba(255, 255, 255, 0.6);"
              onmouseenter="this.style.color='rgba(255,255,255,0.9)'"
              onmouseleave="this.style.color='rgba(255,255,255,0.6)'"
            >
              個人情報保護方針
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-xs font-medium uppercase mb-4" style="letter-spacing: 0.1em; color: rgba(255, 255, 255, 0.3);">
          Contact
        </p>
        <ul class="space-y-3">
          <li>
            <a href="mailto:support@wonder-drill.com" class="text-sm transition-colors" style="color: rgba(255, 255, 255, 0.6);"
              onmouseenter="this.style.color='rgba(255,255,255,0.9)'"
              onmouseleave="this.style.color='rgba(255,255,255,0.6)'"
            >
              support@wonder-drill.com
            </a>
          </li>
          <li>
            <span class="text-sm" style="color: rgba(255, 255, 255, 0.6);">
              Wonder Drill株式会社
            </span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-6" style="border-top: 1px solid rgba(255, 255, 255, 0.1);">
      <p class="text-center text-xs" style="color: rgba(255, 255, 255, 0.3);">
        &copy; {currentYear} Wonder Drill Inc. All rights reserved.
      </p>
    </div>
  </div>
</footer>
