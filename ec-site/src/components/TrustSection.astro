---
// Trust badges section
---

<section class="section-white" style="padding: var(--section-padding) 0;">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 stagger-children">

      <!-- 全国配送対応 -->
      <div class="trust-card animate-on-scroll">
        <div class="trust-icon">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-dmat-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
          </svg>
        </div>
        <h3 class="text-sm font-medium text-dmat-navy mb-1">全国配送対応</h3>
        <p class="text-xs text-gray-400 font-light leading-relaxed">日本全国どこでもお届け</p>
      </div>

      <!-- 10日以内に発送 -->
      <div class="trust-card animate-on-scroll">
        <div class="trust-icon">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-dmat-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-sm font-medium text-dmat-navy mb-1">10日以内に発送</h3>
        <p class="text-xs text-gray-400 font-light leading-relaxed">受注生産で丁寧にお届け</p>
      </div>

      <!-- 安心の品質保証 -->
      <div class="trust-card animate-on-scroll">
        <div class="trust-icon">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-dmat-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <h3 class="text-sm font-medium text-dmat-navy mb-1">安心の品質保証</h3>
        <p class="text-xs text-gray-400 font-light leading-relaxed">不良品は無償交換対応</p>
      </div>

      <!-- メールでサポート -->
      <div class="trust-card animate-on-scroll">
        <div class="trust-icon">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-dmat-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <h3 class="text-sm font-medium text-dmat-navy mb-1">メールでサポート</h3>
        <p class="text-xs text-gray-400 font-light leading-relaxed">お気軽にお問い合わせください</p>
      </div>

    </div>
  </div>
</section>
