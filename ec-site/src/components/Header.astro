---
// Header — Dieter Rams: "Less, but better"
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 bg-white" role="banner" style="height: 64px;">
  <div class="mx-auto px-6 h-full flex items-center justify-between" style="max-width: 72rem;">
    <!-- Logo: typography only -->
    <a href="/" class="text-[var(--color-primary,#1B2838)] font-bold text-base" style="letter-spacing: 0.06em;" aria-label="DMAT STORE トップページ">
      DMAT STORE
    </a>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="sm:hidden p-1" aria-label="メニューを開く">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Navigation -->
    <nav class="hidden sm:flex items-center gap-6" aria-label="メインナビゲーション">
      <a
        href="/#recommended"
        class="text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors"
      >
        Products
      </a>

      <!-- Cart -->
      <a href="/cart" class="relative p-1" aria-label="ショッピングカート">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-gray-500 hover:text-gray-900 transition-colors"
        >
          <path d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
        </svg>
        <!-- Minimal dot indicator — no number -->
        <span
          id="cart-badge"
          class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full"
          style="display: none;"
        ></span>
      </a>
    </nav>
  </div>
</header>

<!-- Mobile menu overlay -->
<div id="mobile-menu" class="fixed inset-0 z-50 bg-white hidden">
  <div class="flex items-center justify-between px-6" style="height: 64px;">
    <span class="font-bold" style="color: var(--color-primary); letter-spacing: 0.06em;">DMAT STORE</span>
    <button onclick="closeMobileMenu()" class="p-1" aria-label="メニューを閉じる">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <nav class="px-6 py-4 space-y-5">
    <a href="/#recommended" class="block text-base font-medium" style="color: var(--color-text-primary);" onclick="closeMobileMenu()">おすすめ商品</a>
    <a href="/#how-to-use" class="block text-base font-medium" style="color: var(--color-text-primary);" onclick="closeMobileMenu()">キーホルダーの使い方</a>
    <a href="/#categories" class="block text-base font-medium" style="color: var(--color-text-primary);" onclick="closeMobileMenu()">カテゴリーから探す</a>
    <a href="/product?custom=true" class="block text-base font-medium" style="color: var(--color-text-primary);" onclick="closeMobileMenu()">自分のキーホルダーを作る</a>
    <a href="/cart" class="block text-base font-medium" style="color: var(--color-text-primary);" onclick="closeMobileMenu()">カート</a>
    <div class="border-t pt-5 mt-2 space-y-3">
      <a href="/legal/tokushoho" class="block text-sm" style="color: var(--color-text-tertiary);" onclick="closeMobileMenu()">特定商取引法に基づく表記</a>
      <a href="/legal/privacy" class="block text-sm" style="color: var(--color-text-tertiary);" onclick="closeMobileMenu()">プライバシーポリシー</a>
      <a href="/legal/protection" class="block text-sm" style="color: var(--color-text-tertiary);" onclick="closeMobileMenu()">個人情報保護方針</a>
    </div>
  </nav>
</div>

<!-- Spacer to offset fixed header -->
<div style="height: 64px;"></div>

<script is:inline>
  (function () {
    function updateCartBadge() {
      var badge = document.getElementById('cart-badge');
      if (!badge) return;
      try {
        var cart = JSON.parse(localStorage.getItem('dmat_cart') || '[]');
        var count = cart.reduce(function (sum, item) {
          return sum + (item.quantity || 1);
        }, 0);
        badge.style.display = count > 0 ? 'block' : 'none';
      } catch (e) {
        badge.style.display = 'none';
      }
    }

    var header = document.getElementById('site-header');
    function onScroll() {
      if (!header) return;
      if (window.scrollY > 0) {
        header.style.borderBottom = '1px solid rgba(0, 0, 0, 0.08)';
      } else {
        header.style.borderBottom = '1px solid transparent';
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    updateCartBadge();
    window.addEventListener('storage', updateCartBadge);
    window.addEventListener('cart-updated', updateCartBadge);

    // Mobile menu
    var menuToggle = document.getElementById('menu-toggle');
    if (menuToggle) {
      menuToggle.addEventListener('click', function () {
        document.getElementById('mobile-menu').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    }

    window.closeMobileMenu = function () {
      document.getElementById('mobile-menu').classList.add('hidden');
      document.body.style.overflow = '';
    };
  })();
</script>
