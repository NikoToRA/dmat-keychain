---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'DMATキーホルダー・DMATグッズの通販。NFC内蔵、EMISを誰でも簡単に入力できるように支援。DMAT隊員・災害拠点病院向け。受注生産、全国配送。' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- 旧Azure URLからカスタムドメインへ301相当リダイレクト -->
  <script is:inline>
    if (location.hostname === 'thankful-sand-00abb1300.4.azurestaticapps.net') {
      location.replace('https://shop.wonder-drill.com' + location.pathname + location.search);
    }
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/images/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="/images/og-image.png" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href={`https://shop.wonder-drill.com${Astro.url.pathname}`} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Analytics Config -->
  <script is:inline>
    window.DMAT_CLARITY_ID = '';
    window.DMAT_GA4_ID = '';
  </script>

  <!-- Analytics -->
  <script is:inline>
    (function () {
      'use strict';

      // Microsoft Clarity
      var CLARITY_PROJECT_ID = window.DMAT_CLARITY_ID || '';
      if (CLARITY_PROJECT_ID) {
        (function (c, l, a, r, i, t, y) {
          c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments); };
          t = l.createElement(r); t.async = 1; t.src = 'https://www.clarity.ms/tag/' + i;
          y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
        })(window, document, 'clarity', 'script', CLARITY_PROJECT_ID);
      }

      // Google Analytics 4
      var GA4_MEASUREMENT_ID = window.DMAT_GA4_ID || '';
      if (GA4_MEASUREMENT_ID) {
        var script = document.createElement('script');
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA4_MEASUREMENT_ID;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', GA4_MEASUREMENT_ID);
      }

      // Custom event helper
      window.trackEvent = function (eventName, params) {
        if (window.gtag) {
          window.gtag('event', eventName, params || {});
        }
        if (window.clarity) {
          window.clarity('set', eventName, JSON.stringify(params || {}));
        }
      };

      // EC conversion: checkout button
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('#checkout-button');
        if (btn) {
          var total = typeof getCartTotal === 'function' ? getCartTotal() : null;
          window.trackEvent('begin_checkout', {
            currency: 'JPY',
            value: total ? total.subtotal : 0,
            items_count: total ? total.totalQuantity : 0,
          });
        }
      });

      // Purchase tracking on thanks page
      if (window.location.pathname.includes('thanks')) {
        var urlParams = new URLSearchParams(window.location.search);
        var sessionId = urlParams.get('session_id');
        if (sessionId) {
          window.trackEvent('purchase', {
            transaction_id: sessionId,
            currency: 'JPY',
          });
        }
      }
    })();
  </script>

  <!-- Schema.org structured data for AI/LLM discovery -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "DMAT STORE",
    "url": "https://shop.wonder-drill.com",
    "description": "DMATキーホルダー・DMATグッズの公式通販サイト。NFC内蔵、かざすだけでEMISへ即アクセス。DMAT隊員用・災害拠点病院向け装備品の受注生産販売。",
    "publisher": {
      "@type": "Organization",
      "name": "Wonder Drill株式会社",
      "email": "support@wonder-drill.com",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "JP",
        "postalCode": "064-0805",
        "addressRegion": "北海道",
        "addressLocality": "札幌市中央区",
        "streetAddress": "南5条西15丁目2-3 リズム医大前503号室"
      }
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://shop.wonder-drill.com/category?cat={search_term}",
      "query-input": "required name=search_term"
    }
  }
  </script>
</head>
<body class="min-h-screen flex flex-col bg-[#FAFBFC]">
  <Header />

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- Scroll Animation Observer -->
  <script is:inline>
    (function () {
      function initAnimations() {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.01, rootMargin: '50px' });

        function observe() {
          document.querySelectorAll('.animate-on-scroll:not(.is-visible)').forEach(function (el) {
            observer.observe(el);
          });
        }

        observe();

        // Re-observe when DOM changes (dynamic content)
        new MutationObserver(observe).observe(document.body, { childList: true, subtree: true });
      }

      // Run after everything is loaded
      if (document.readyState === 'complete') {
        initAnimations();
      } else {
        window.addEventListener('load', initAnimations);
      }

      // Safety: show all content after 1s regardless
      setTimeout(function () {
        document.querySelectorAll('.animate-on-scroll:not(.is-visible)').forEach(function (el) {
          el.classList.add('is-visible');
        });
      }, 1000);
    })();
  </script>

  <!-- Toast Container -->
  <div id="toast-container"></div>
</body>
</html>
